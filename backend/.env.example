PORT=3000
NODE_ENV=development

# TiDB Cloud: host에 tidbcloud.com 포함 시 SSL 자동 적용 (또는 DB_SSL=true)
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=favorite_photo
# Render env 이름: DB_USER (not DB_USERNAME), DB_NAME (not DB_DATABASE)

JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# OAuth (선택)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BACKEND_PUBLIC_URL=http://localhost:3000

# PHOTO_CARD_MONTHLY_LIMIT=3
